{
	"name": "hr-time",
	"private": true,
	"scripts": {
		"dev": "pnpm --filter @hr-time/backend dev & pnpm --filter @hr-time/frontend dev",
		"dev:backend": "pnpm --filter @hr-time/backend dev",
		"dev:frontend": "pnpm --filter @hr-time/frontend dev",
		"build": "pnpm --filter @hr-time/frontend build && cp -r packages/frontend/dist/* packages/backend/public/ && pnpm --filter @hr-time/backend build",
		"test": "dotenv -e packages/backend/.env -- vitest run",
		"db:up": "docker compose up -d",
		"db:down": "docker compose down",
		"db:migrate": "pnpm --filter @hr-time/backend db:migrate",
		"typecheck": "pnpm -r run --if-present typecheck",
		"db:studio": "pnpm --filter @hr-time/backend db:studio",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css}": "biome check --write"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"dotenv-cli": "^11.0.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.0",
		"lint-staged": "^16.4.0",
		"vitest": "^3.2.4"
	},
	"packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977"
}
